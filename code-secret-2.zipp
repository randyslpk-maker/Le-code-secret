<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Code Secret</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Outfit:wght@300;600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0b0f1a;
      --panel: #111827;
      --border: #1e2d3d;
      --accent: #00e5ff;
      --accent-dim: rgba(0,229,255,0.12);
      --red: #ff3b5c;
      --green: #00e5a0;
      --text: #c9d6e3;
      --mono: 'Share Tech Mono', monospace;
      --sans: 'Outfit', sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      overflow: hidden;
    }

    /* Scanline ambient */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0,229,255,0.012) 3px,
        rgba(0,229,255,0.012) 4px
      );
      pointer-events: none;
      z-index: 100;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2.5rem 2rem;
      width: min(380px, 92vw);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.8rem;
      position: relative;
      box-shadow: 0 0 40px rgba(0,229,255,0.04), 0 4px 32px rgba(0,0,0,0.6);
    }

    /* Corner decorations */
    .panel::before, .panel::after {
      content: '';
      position: absolute;
      width: 14px; height: 14px;
      border-color: var(--accent);
      border-style: solid;
    }
    .panel::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; border-radius: 12px 0 0 0; }
    .panel::after  { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; border-radius: 0 0 12px 0; }

    .header {
      text-align: center;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    h1 {
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: #e8f0f8;
    }

    /* 4-digit display */
    .display {
      display: flex;
      gap: 0.7rem;
    }

    .digit-cell {
      width: 52px;
      height: 64px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 1.9rem;
      color: var(--accent);
      background: rgba(0,229,255,0.04);
      transition: border-color 0.15s, box-shadow 0.15s;
      position: relative;
    }

    .digit-cell.active {
      border-color: var(--accent);
      box-shadow: 0 0 14px rgba(0,229,255,0.25);
    }

    .digit-cell.filled {
      border-color: rgba(0,229,255,0.4);
    }

    /* Cursor blink inside active cell */
    .digit-cell.active::after {
      content: '';
      position: absolute;
      bottom: 12px;
      width: 20px; height: 2px;
      background: var(--accent);
      animation: blink 0.9s step-end infinite;
    }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* Numpad */
    .numpad {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.55rem;
      width: 100%;
    }

    .key {
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 0;
      font-family: var(--mono);
      font-size: 1.1rem;
      color: var(--text);
      cursor: pointer;
      transition: background 0.1s, transform 0.07s, border-color 0.1s;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    .key:hover { background: rgba(0,229,255,0.08); border-color: rgba(0,229,255,0.3); }
    .key:active { transform: scale(0.93); background: rgba(0,229,255,0.14); }

    .key.del {
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      color: var(--red);
      border-color: rgba(255,59,92,0.2);
    }
    .key.del:hover { background: rgba(255,59,92,0.08); border-color: rgba(255,59,92,0.4); }

    /* Status bar */
    .status {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      min-height: 1.2em;
      color: var(--text);
      opacity: 0.5;
      transition: color 0.3s, opacity 0.3s;
    }

    .status.error  { color: var(--red);   opacity: 1; }
    .status.ok     { color: var(--green); opacity: 1; }

    /* Shake animation on error */
    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20%      { transform: translateX(-8px); }
      40%      { transform: translateX(8px); }
      60%      { transform: translateX(-5px); }
      80%      { transform: translateX(5px); }
    }
    .shake { animation: shake 0.4s ease; }

    /* ---- SUCCESS OVERLAY ---- */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(11,15,26,0.92);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.2rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s;
      z-index: 50;
    }

    .overlay.show {
      opacity: 1;
      pointer-events: all;
    }

    .badge {
      width: 72px; height: 72px;
      border-radius: 50%;
      border: 2px solid var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 30px rgba(0,229,160,0.35);
      font-size: 2rem;
    }

    .mot-secret-label {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--green);
    }

    .mot-secret {
      font-family: var(--mono);
      font-size: 2.8rem;
      letter-spacing: 0.18em;
      color: #fff;
      text-shadow: 0 0 24px rgba(0,229,160,0.5);
    }

    .retry-btn {
      margin-top: 0.8rem;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 1.4rem;
      font-family: var(--sans);
      font-size: 0.8rem;
      color: var(--text);
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .retry-btn:hover { border-color: var(--accent); background: rgba(0,229,255,0.06); color: var(--accent); }
  </style>
</head>
<body>

  <!-- Main panel -->
  <div class="panel" id="panel">
    <div class="header">
      <div class="eyebrow">Accès restreint</div>
      <h1>Entrez le code</h1>
    </div>

    <div class="display" id="display">
      <div class="digit-cell active" id="c0"></div>
      <div class="digit-cell" id="c1"></div>
      <div class="digit-cell" id="c2"></div>
      <div class="digit-cell" id="c3"></div>
    </div>

    <div class="status" id="status">_ _ _ _</div>

    <div class="numpad">
      <button class="key" onclick="press('1')">1</button>
      <button class="key" onclick="press('2')">2</button>
      <button class="key" onclick="press('3')">3</button>
      <button class="key" onclick="press('4')">4</button>
      <button class="key" onclick="press('5')">5</button>
      <button class="key" onclick="press('6')">6</button>
      <button class="key" onclick="press('7')">7</button>
      <button class="key" onclick="press('8')">8</button>
      <button class="key" onclick="press('9')">9</button>
      <button class="key del" onclick="del()">⌫ DEL</button>
      <button class="key" onclick="press('0')">0</button>
      <button class="key del" onclick="reset()">CLR</button>
    </div>
  </div>

  <!-- Success overlay -->
  <div class="overlay" id="overlay">
    <div class="badge">🔓</div>
    <div class="mot-secret-label">Mot secret</div>
    <div class="mot-secret">VISITE</div>
    <button class="retry-btn" onclick="closeOverlay()">Fermer</button>
  </div>

  <script>
    const SECRET = '2769'; // ← change le code ici
    let digits = [];

    function updateDisplay() {
      for (let i = 0; i < 4; i++) {
        const cell = document.getElementById('c' + i);
        cell.textContent = digits[i] !== undefined ? '●' : '';
        cell.className = 'digit-cell';
        if (i < digits.length) cell.classList.add('filled');
        if (i === digits.length && digits.length < 4) cell.classList.add('active');
      }
    }

    function press(d) {
      if (digits.length >= 4) return;
      digits.push(d);
      updateDisplay();
      if (digits.length === 4) setTimeout(check, 180);
    }

    function del() {
      digits.pop();
      setStatus('_ _ _ _', '');
      updateDisplay();
    }

    function reset() {
      digits = [];
      setStatus('_ _ _ _', '');
      updateDisplay();
    }

    function check() {
      if (digits.join('') === SECRET) {
        setStatus('Accès accordé', 'ok');
        setTimeout(() => document.getElementById('overlay').classList.add('show'), 300);
      } else {
        setStatus('Code incorrect', 'error');
        const panel = document.getElementById('panel');
        panel.classList.add('shake');
        panel.addEventListener('animationend', () => panel.classList.remove('shake'), { once: true });
        setTimeout(reset, 700);
      }
    }

    function setStatus(msg, cls) {
      const s = document.getElementById('status');
      s.textContent = msg;
      s.className = 'status ' + cls;
    }

    function closeOverlay() {
      document.getElementById('overlay').classList.remove('show');
      reset();
    }

    // Keyboard support
    document.addEventListener('keydown', e => {
      if (e.key >= '0' && e.key <= '9') press(e.key);
      if (e.key === 'Backspace') del();
      if (e.key === 'Escape') reset();
    });

    updateDisplay();
  </script>
</body>
</html>
